# Discord bot token from https://discord.com/developers/applications
BOT_TOKEN=

# Application/Client ID of your bot
CLIENT_ID=

# The ONLY server this bot is allowed to operate the ticket system in
GUILD_ID=

# MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=

# IMPORTANT: dotenv is pinned to v16 in package.json. Do not upgrade to v17,
# which injects an unwanted advertisement banner on load.
